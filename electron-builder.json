{
  "appId": "com.imageoptimizer.app",
  "productName": "Image Optimizer",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "asar": true,
  "asarUnpack": [
    "node_modules/sharp/**/*",
    "node_modules/@img/**/*"
  ],
  "mac": {
    "category": "public.app-category.graphics-design",
    "target": ["zip"]
  },
  "win": {
    "target": ["nsis", "portable"]
  },
  "linux": {
    "target": ["AppImage", "deb"]
  }
}
